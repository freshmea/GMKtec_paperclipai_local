{
  "$schema": "https://opencode.ai/config.json",
  "disabled_providers": [],
  "provider": {
    "local_llm": {
      "name": "Local LLM — 31B (고품질)",
      "npm": "@ai-sdk/openai-compatible",
      "models": {
        "gemma-4-31b-it": {
          "name": "Gemma 4 31B (고품질, 느림)"
        }
      },
      "options": {
        "baseURL": "http://llm:8000/v1"
      }
    },
    "local_llm_fast": {
      "name": "Local LLM — E4B (고속)",
      "npm": "@ai-sdk/openai-compatible",
      "models": {
        "gemma-4-e4b-it": {
          "name": "Gemma 4 E4B (경량, 빠름)"
        }
      },
      "options": {
        "baseURL": "http://llm-fast:8000/v1"
      }
    }
  }
}
