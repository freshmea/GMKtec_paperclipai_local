{
  "$schema": "https://opencode.ai/config.json",
  "disabled_providers": ["local_llm", "local_llm_fast"],
  "provider": {
    "local_llm_moe": {
      "name": "Local LLM — Gemma 4 26B-A4B",
      "npm": "@ai-sdk/openai-compatible",
      "models": {
        "gemma-4-26b-a4b-it": {
          "name": "Gemma 4 26B-A4B (shorter/mid-context)",
          "limit": {
            "context": 65536,
            "output": 8192
          }
        }
      },
      "options": {
        "baseURL": "http://llm-moe:8000/v1"
      }
    },
    "local_llm_qwen": {
      "name": "Local LLM — Qwen3.6 35B-A3B",
      "npm": "@ai-sdk/openai-compatible",
      "models": {
        "qwen3-6-35b-a3b": {
          "name": "Qwen3.6 35B-A3B (long-context, technical)",
          "limit": {
            "context": 131072,
            "output": 8192
          }
        }
      },
      "options": {
        "baseURL": "http://llm-qwen:8000/v1"
      }
    },
    "local_llm": {
      "name": "Local LLM — Gemma 4 31B Dense (legacy)",
      "npm": "@ai-sdk/openai-compatible",
      "models": {
        "gemma-4-31b-it": {
          "name": "Gemma 4 31B (legacy optional)",
          "limit": {
            "context": 65536,
            "output": 8192
          }
        }
      },
      "options": {
        "baseURL": "http://llm:8000/v1"
      }
    },
    "local_llm_fast": {
      "name": "Local LLM — E4B (legacy)",
      "npm": "@ai-sdk/openai-compatible",
      "models": {
        "gemma-4-e4b-it": {
          "name": "Gemma 4 E4B (legacy, very fast)",
          "limit": {
            "context": 32768,
            "output": 8192
          }
        }
      },
      "options": {
        "baseURL": "http://llm-fast:8000/v1"
      }
    }
  },
  // 컨텍스트가 limit.context에 근접하면 자동으로 대화를 요약/압축
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 4096
  }
}
