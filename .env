# =============================================================================
# 환경 변수 설정
# .env.example → .env 로 복사 후 수정하여 사용
# =============================================================================

# --- 모델 설정 ---
MODEL_DIR=./models
MODEL_FILENAME=gemma-4-31B-it-Q4_K_M.gguf
SERVED_MODEL_NAME=gemma-4-31b-it
CONTEXT_LENGTH=131072
PARALLEL_SLOTS=2

# --- llama-server 설정 (31B, 고품질) ---
LLM_PORT=8000
LLM_MEMORY_LIMIT=64g
OMP_NUM_THREADS=32
GPU_MAX_HW_QUEUES=2

# --- llama-server-fast 설정 (E4B, 고속) ---
FAST_MODEL_FILENAME=gemma-4-E4B-it-Q4_K_M.gguf
FAST_SERVED_MODEL_NAME=gemma-4-e4b-it
FAST_LLM_PORT=8001
FAST_CONTEXT_LENGTH=131072
FAST_PARALLEL_SLOTS=4
FAST_LLM_MEMORY_LIMIT=16g
FAST_OMP_NUM_THREADS=16

# --- llama-server-moe 설정 (26B MoE, 균형) ---
MOE_MODEL_FILENAME=google_gemma-4-26B-A4B-it-Q4_K_M.gguf
MOE_SERVED_MODEL_NAME=gemma-4-26b-a4b-it
MOE_LLM_PORT=8002
MOE_CONTEXT_LENGTH=131072
MOE_PARALLEL_SLOTS=1
MOE_LLM_MEMORY_LIMIT=48g
MOE_OMP_NUM_THREADS=32

# --- vLLM 설정 (참고용, 현재 docker-compose.yml에서는 미사용) ---
# VLLM_PORT=8000
# VLLM_MEMORY_LIMIT=48g
# VLLM_CPU_KVCACHE_SPACE=40
# MAX_MODEL_LEN=8192

# --- OpenCode 설정 ---
OPENCODE_PORT=3000
OPENAI_API_KEY=sk-no-key-required
WORKSPACE_DIR=./workspace

# --- PaperClip 설정 ---
PAPERCLIP_PORT=3100
PG_USER=paperclip
PG_PASSWORD=paperclip
PG_DB=paperclip
PAPERCLIP_PUBLIC_URL=http://localhost:3100
BETTER_AUTH_SECRET=change-this-secret-in-production

# --- HuggingFace 토큰 (비공개 모델 다운로드 시 필요) ---
# HF_TOKEN=hf_your_token_here
