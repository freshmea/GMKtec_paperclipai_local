{
  "$schema": "https://opencode.ai/config.json",
  "disabled_providers": ["local_llm"],
  "provider": {
    // 31B — docker-compose에서 비활성화 상태 (disabled_providers에 추가)
    "local_llm": {
      "name": "Local LLM — 31B (고품질, 현재 비활성화)",
      "npm": "@ai-sdk/openai-compatible",
      "models": {
        "gemma-4-31b-it": {
          "name": "Gemma 4 31B (고품질, 느림)",
          "limit": {
            "context": 131072,
            "output": 8192
          }
        }
      },
      "options": {
        "baseURL": "http://llm:8000/v1"
      }
    },
    "local_llm_fast": {
      "name": "Local LLM — E4B (고속)",
      "npm": "@ai-sdk/openai-compatible",
      "models": {
        "gemma-4-e4b-it": {
          "name": "Gemma 4 E4B (경량, 빠름)",
          "limit": {
            "context": 131072,
            "output": 8192
          }
        }
      },
      "options": {
        "baseURL": "http://llm-fast:8000/v1"
      }
    },
    "local_llm_moe": {
      "name": "Local LLM — 26B MoE (균형)",
      "npm": "@ai-sdk/openai-compatible",
      "models": {
        "gemma-4-26b-a4b-it": {
          "name": "Gemma 4 26B MoE (빠른 속도 + 높은 품질)",
          "limit": {
            "context": 131072,
            "output": 8192
          }
        }
      },
      "options": {
        "baseURL": "http://llm-moe:8000/v1"
      }
    }
  },
  // 컨텍스트가 limit.context에 근접하면 자동으로 대화를 요약/압축
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 4096
  }
}
