# =============================================================================
# 환경 변수 설정
# .env.example → .env 로 복사 후 수정하여 사용
# =============================================================================

# --- 기본 운영 모델 조합 ---
# Gemma 4 26B-A4B (shorter/mid-context) + Qwen3.6 35B-A3B (long-context)
MODEL_DIR=./models

# --- legacy: llama-server 설정 (Gemma 4 31B Dense, optional) ---
MODEL_FILENAME=gemma-4-31B-it-Q4_K_M.gguf
SERVED_MODEL_NAME=gemma-4-31b-it
CONTEXT_LENGTH=65536
PARALLEL_SLOTS=1

# --- legacy: llama-server 설정 (Gemma 4 31B Dense) ---
LLM_PORT=8000
LLM_MEMORY_LIMIT=56g
OMP_NUM_THREADS=32
GPU_MAX_HW_QUEUES=2

# --- llama-server 설정 (Gemma 4 26B-A4B, 기본 shorter/mid-context) ---
MOE_MODEL_FILENAME=google_gemma-4-26B-A4B-it-Q4_K_M.gguf
MOE_SERVED_MODEL_NAME=gemma-4-26b-a4b-it
MOE_LLM_PORT=8002
MOE_CONTEXT_LENGTH=65536
MOE_PARALLEL_SLOTS=1
MOE_LLM_MEMORY_LIMIT=48g
MOE_OMP_NUM_THREADS=32

# --- llama-server 설정 (Qwen3.6 35B-A3B, 긴 컨텍스트) ---
QWEN_MODEL_FILENAME=Qwen3.6-35B-A3B-UD-Q4_K_M.gguf
QWEN_SERVED_MODEL_NAME=qwen3-6-35b-a3b
QWEN_LLM_PORT=8003
QWEN_CONTEXT_LENGTH=131072
QWEN_PARALLEL_SLOTS=1
QWEN_LLM_MEMORY_LIMIT=64g
QWEN_OMP_NUM_THREADS=32

# --- legacy: llama-server-fast 설정 (E4B, 고속) ---
FAST_MODEL_FILENAME=gemma-4-E4B-it-Q4_K_M.gguf
FAST_SERVED_MODEL_NAME=gemma-4-e4b-it
FAST_LLM_PORT=8001
FAST_CONTEXT_LENGTH=131072
FAST_PARALLEL_SLOTS=4
FAST_LLM_MEMORY_LIMIT=16g
FAST_OMP_NUM_THREADS=16

# --- vLLM 설정 (참고용, 현재 docker-compose.yml에서는 미사용) ---
# VLLM_PORT=8000
# VLLM_MEMORY_LIMIT=48g
# VLLM_CPU_KVCACHE_SPACE=40
# MAX_MODEL_LEN=8192

# --- OpenCode 설정 ---
OPENCODE_PORT=3000
OPENAI_API_KEY=sk-no-key-required
WORKSPACE_DIR=./workspace

# --- ComfyUI 설정 ---
COMFYUI_PORT=3001
COMFYUI_INTERNAL_PORT=8188
COMFYUI_LISTEN=0.0.0.0
COMFYUI_REF=v0.19.3
COMFYUI_BASE_IMAGE=rocm/pytorch:rocm7.2_ubuntu24.04_py3.12_pytorch_release_2.8.0

# --- PaperClip 설정 ---
PAPERCLIP_PORT=3100
PG_USER=paperclip
PG_PASSWORD=paperclip
PG_DB=paperclip
PAPERCLIP_PUBLIC_URL=http://localhost:3100
BETTER_AUTH_SECRET=change-this-secret-in-production

# --- HuggingFace 토큰 (비공개 모델 다운로드 시 필요) ---
# HF_TOKEN=hf_your_token_here
